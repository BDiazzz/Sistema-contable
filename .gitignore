
```gitignore
# Entornos virtuales
venv/
.env/
.venv/

# Archivos de entorno
*.env
.env.*

# Archivos de base de datos local
db.sqlite3

# Archivos compilados de Python
__pycache__/
*.py[cod]
*$py.class

# Archivos de logs
*.log

# Archivos temporales del sistema
.DS_Store
Thumbs.db

# Migraciones (comentadas para que sí se suban)
# */migrations/*.py
# !*/migrations/__init__.py

# Archivos estáticos generados
staticfiles/
media/

# Archivos de IDEs y editores
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
